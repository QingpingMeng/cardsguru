{
  "name": "cardsguru",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "CardsGuru — track recurring credit card benefits, sync to your own private GitHub repo.",
  "scripts": {
    "sync:catalog": "node scripts/sync-catalog.mjs",
    "gen:icons": "node scripts/generate-icons.mjs",
    "predev": "node scripts/sync-catalog.mjs && node scripts/generate-icons.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-catalog.mjs && node scripts/generate-icons.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.28",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.14.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "fake-indexeddb": "^5.0.2",
    "jsdom": "^24.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^2.0.5",
    "workbox-window": "7.1.0"
  },
  "overrides": {
    "workbox-build": "7.1.1",
    "workbox-window": "7.1.0"
  }
}
